# notion_manager 환경변수 명세
# 실제 값은 저장소 루트의 .env (gitignore 대상)에만 넣는다. 이 파일에는 절대 실제 시크릿을 쓰지 말 것.

# ── Discord ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=            # notion_manager 봇 토큰 (Developer Portal > Bot)
DISCORD_CLIENT_ID=1527539169793019985
DISCORD_CLIENT_SECRET=        # OAuth2 클라이언트 시크릿
DISCORD_GUILD_ID=             # 스터디 서버(길드) ID
DISCORD_WATCH_CHANNEL_ID=     # 노션 관리 요청을 모니터링할 채널 ID (예: #노션-관리)

# ── Notion ───────────────────────────────────────────────
NOTION_TOKEN=                 # Notion integration token (ntn_...)
NOTION_ROOT_PAGE_ID=c1c46a9b9796822fb0ef017f31d4b544   # 개발 스터디그룹 홈

# 주요 데이터베이스 (docs/NOTION_AGENT_HANDOVER.md 5장 워크스페이스 맵 참조)
NOTION_DB_TRACKER=0a146a9b979683b5bd4a01cde13bfab5     # 스터디 학습 트래커 DB
NOTION_DS_TRACKER=78f46a9b-9796-8384-9c4e-07f3ae3c8e25 # └ data source ID
NOTION_DB_SCHEDULE=a62c37ef41834859b6ede4553658f668    # 스터디 일정 DB
NOTION_DS_SCHEDULE=45522dc8-135a-4934-9516-4adebb076ca5
NOTION_DB_RESOURCES=ff6d8e254972456f8fa08b43f4c710cf   # 공유 자료실 DB
NOTION_DS_RESOURCES=b1fac88e-e2b7-4812-bd4c-324090cbc90d

# ── LLM Provider ─────────────────────────────────────────
LLM_PROVIDER=openai           # openai | anthropic
# 프로바이더에 맞는 모델명. 비우면 프로바이더 기본값.
#   anthropic: claude-sonnet-5 (빠름/저렴) | claude-opus-4-8 (최고 성능)
#   openai   : gpt-5.6-luna (저비용) | gpt-5.5 (프론티어)
LLM_MODEL=gpt-5.5

# ── Claude API (LLM_PROVIDER=anthropic 또는 폴백용) ───────
ANTHROPIC_API_KEY=            # Claude API 키
CLAUDE_MODEL=claude-opus-4-8  # 폴백 런타임 에이전트 모델

# ── OpenAI API (LLM_PROVIDER=openai) ─────────────────────
OPENAI_API_KEY=               # OpenAI API 키
OPENAI_BASE_URL=https://api.openai.com/v1
